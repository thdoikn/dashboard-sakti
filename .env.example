# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL - SAKTI data
MYSQL_DATA_DB=sakti_data
MYSQL_DATA_USER=sakti_app
MYSQL_DATA_PASSWORD=
MYSQL_HOST=mysql
MYSQL_PORT=3306

# MySQL - Airflow metadata (same instance, different db & user)
MYSQL_AIRFLOW_DB=airflow_metadata
MYSQL_AIRFLOW_USER=airflow_app
MYSQL_AIRFLOW_PASSWORD=

# MySQL root (for initial container setup)
MYSQL_ROOT_PASSWORD=

# SAKTI API client
SAKTI_API_BASE_URL=http://backend:8000/sitp-monsakti-omspan/webservice
SAKTI_GATEWAY_API_KEY=dummy-key-for-dev

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
